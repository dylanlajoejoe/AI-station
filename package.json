{
  "name": "ai-workspace-connector",
  "version": "0.1.0",
  "private": true,
  "description": "轻量级 AI 工作区连接器",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"node scripts/wait-for-dev.cjs && npm run rebuild:native && electron dist-electron/main.js\"",
    "build": "tsc -p electron/tsconfig.json && tsc -p tsconfig.json && vite build",
    "test": "tsc -p electron/tsconfig.json && node scripts/context-compress.test.cjs",
    "postinstall": "npm run rebuild:native",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "highlight.js": "11.11.1",
    "officeparser": "^7.2.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "5.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "electron": "39.8.5",
    "typescript": "5.9.3",
    "vite": "7.3.5"
  }
}
